# OpenAI-compatible API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
TRANSCRIPTION_MODEL=gpt-4o-transcribe
LLM_MODEL=gpt-4o

# HuggingFace (for pyannote speaker diarization model)
HF_TOKEN=hf_your-token-here

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=meeting_transcriber
DATABASE_URL=postgresql://user:change-me-in-production@localhost:5432/meeting_transcriber

# Redis (job queue)
REDIS_URL=redis://localhost:6379/0

# Storage (local path or S3 URL)
STORAGE_BACKEND=local
STORAGE_PATH=./data/audio
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=

# Service ports
API_PORT=8000
FRONTEND_PORT=3000

# Diarization backend: "local" (ECAPA-TDNN) or "pyannote"
DIARIZATION_BACKEND=local
